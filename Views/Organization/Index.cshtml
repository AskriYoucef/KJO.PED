@{
    ViewData["Title"] = "Organization";
}

<section class="page-section">
    <div class="container">
        <div class="content-card mb-4">
            <div class="section-kicker">Organization</div>
            <h1 class="card-title-main">Petroleum Engineering & Exploration Department</h1>
            <p class="page-text mb-0">
                Explore the department structure, key functions, major teams and the general organization of PED within Khafji Joint Operations.
            </p>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-8">
                <div class="content-card h-100">
                    <div class="section-kicker">Department Overview</div>
                    <h2 class="card-title-main">Role of PED within KJO</h2>
                    <p class="page-text">
                        The Petroleum Engineering & Exploration Department supports petroleum engineering,
                        exploration, technical analysis and coordination activities across the organization.
                    </p>
                    <p class="page-text mb-0">
                        PED contributes to operational efficiency, technical decision-making and the delivery
                        of engineering and exploration-related services through close collaboration with internal stakeholders.
                    </p>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="content-card h-100">
                    <h2 class="quick-card-title mb-4">At a Glance</h2>
                    <ul class="link-list mb-0">
                        <li>Departmental coordination and technical support</li>
                        <li>Engineering and exploration-related activities</li>
                        <li>Cross-functional collaboration</li>
                        <li>Support for planning, analysis and operations</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-6 col-xl-3">
                <div class="info-card h-100">
                    <h3 class="info-card-title mb-3">Department Management</h3>
                    <p class="info-card-text">
                        Oversees strategy, priorities, coordination and alignment of department activities with KJO objectives.
                    </p>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="info-card h-100">
                    <h3 class="info-card-title mb-3">Exploration Team</h3>
                    <p class="info-card-text">
                        Supports exploration studies, technical reviews and data-driven activities related to subsurface evaluation.
                    </p>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="info-card h-100">
                    <h3 class="info-card-title mb-3">Reservoir Engineering</h3>
                    <p class="info-card-text">
                        Contributes to reservoir analysis, production optimization and engineering support for field development.
                    </p>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="info-card h-100">
                    <h3 class="info-card-title mb-3">Technical Support</h3>
                    <p class="info-card-text">
                        Provides coordination, reporting support, documentation follow-up and operational alignment across teams.
                    </p>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="content-card h-100">
                    <div class="section-kicker">Roles & Responsibilities</div>
                    <h2 class="card-title-main">Key responsibilities</h2>
                    <ul class="link-list mb-0">
                        <li>Support petroleum engineering and exploration-related workflows</li>
                        <li>Provide technical coordination between internal stakeholders</li>
                        <li>Contribute to analysis, reporting and departmental planning</li>
                        <li>Follow up on technical documents, actions and communications</li>
                    </ul>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="content-card h-100">
                    <div class="section-kicker">Current Status</div>
                    <h2 class="card-title-main">Content roadmap</h2>
                    <p class="page-text mb-0">
                        This page can be progressively enriched with the official organizational chart,
                        reporting lines, key contacts, division details and role descriptions as soon as the official content is available.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>