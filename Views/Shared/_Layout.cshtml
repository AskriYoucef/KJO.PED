@{
    var currentPage = (ViewData["Title"]?.ToString() ?? "");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PED Intranet</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="page-shell header-inner">
            <a class="brand-link" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo.png" asp-append-version="true" alt="KJO Logo" class="brand-logo" />
            </a>

            <nav class="top-nav">
                <a class="@(currentPage == "Overview" ? "active" : "")"
                       asp-controller="Home" asp-action="Index">
                    Overview
                </a>

                <a class="@(currentPage == "Organization" ? "active" : "")"
                       asp-controller="Home" asp-action="Organization">
                    Organization
                </a>

                <div class="nav-item has-dropdown">
                    <a class="nav-link @(currentPage == "Applications" ? "active" : "")"
                           asp-controller="Home" asp-action="Applications">
                        Applications
                    </a>
                    <div class="dropdown-menu-custom">
                        <a asp-controller="Home" asp-action="Applications">PED Applications</a>
                        <a asp-controller="Home" asp-action="Applications">KJO Useful Links</a>
                        <a asp-controller="Home" asp-action="EmployeeAccess">Employee Services</a>
                    </div>
                </div>

                <div class="nav-item has-dropdown">
                    <a class="nav-link @(currentPage == "Documents" ? "active" : "")"
                           asp-controller="Home" asp-action="Documents">
                        Documents
                    </a>
                    <div class="dropdown-menu-custom">
                        <a asp-controller="Home" asp-action="Documents">Policies &amp; Procedures</a>
                        <a asp-controller="Home" asp-action="Documents">Reference Documents</a>
                        <a href="@Url.Content("~/docs/operational-calendar-2026.pdf")" target="_blank" rel="noopener">Operational Calendar 2026</a>
                        <a href="@Url.Content("~/docs/azure-information-protection-guide.pdf")" target="_blank" rel="noopener">Azure Information Protection Guide</a>
                    </div>
                </div>

                <div class="nav-item has-dropdown">
                    <a class="nav-link @(currentPage == "News" ? "active" : "")"
                           asp-controller="Home" asp-action="News">
                        News
                    </a>
                    <div class="dropdown-menu-custom">
                        <a asp-controller="Home" asp-action="News">News &amp; Announcements</a>
                        <a asp-controller="Home" asp-action="WeeklyHighlights">Weekly Highlights</a>
                    </div>
                </div>

                <a class="@((currentPage == "Department Directory" || currentPage == "Department Directory") ? "active" : "")"
                       asp-controller="Home" asp-action="CompanyDirectory">
                    Department Directory
                </a>

                <div class="nav-item has-dropdown">
                    <a class="nav-link @(currentPage == "Employee Access" ? "active" : "")"
                           asp-controller="Home" asp-action="EmployeeAccess">
                        Employee Access
                    </a>
                    <div class="dropdown-menu-custom dropdown-menu-right">
                        <a asp-controller="Home" asp-action="EmployeeAccess">Employee Access</a>
                        <a asp-controller="Home" asp-action="WeeklyHighlights">Weekly Highlights</a>
                        <a asp-controller="Home" asp-action="ContactSupport">Contact &amp; Support</a>
                    </div>
                </div>
            </nav>

            <a href="#" class="sign-in-btn">Sign In</a>
        </div>
    </header>

    <main class="site-main">
        <div class="page-shell">
            @await Html.PartialAsync("_PedBanner")
            @RenderBody()
        </div>
    </main>

    <footer class="site-footer">
        <div class="page-shell footer-inner">
            <div class="footer-col footer-brand-col">
                <div class="footer-brand-panel">
                    <img src="~/images/logo_nobg1.png" alt="KJO Logo" class="footer-brand-logo" asp-append-version="true" />
                </div>
                <h3>PED Portal</h3>
                <p>Petroleum Engineering &amp; Exploration Department</p>
                <p>Khafji Joint Operations</p>
                <div class="copyright">© 2026 PED Portal. All rights reserved.</div>
            </div>

            <div class="footer-col">
                <h3>Navigation</h3>
                <div class="footer-links-grid">
                    <a asp-controller="Home" asp-action="Index">Overview</a>
                    <a asp-controller="Home" asp-action="News">News</a>
                    <a asp-controller="Home" asp-action="Organization">Organization</a>
                    <a asp-controller="Home" asp-action="DepartmentDirectory">Department Directory</a>
                    <a asp-controller="Home" asp-action="Applications">Applications</a>
                    <a asp-controller="Home" asp-action="EmployeeAccess">Employee Access</a>
                    <a asp-controller="Home" asp-action="Documents">Documents</a>
                    <a asp-controller="Home" asp-action="WeeklyHighlights">Weekly Highlights</a>
                </div>
            </div>

            <div class="footer-col">
                <h3>Useful Access</h3>
                <p>
                    Find department references, contact points, weekly highlights
                    and the operational calendar from one place.
                </p>

                <div class="footer-cta-group">
                    <a class="footer-mini-btn" asp-controller="Home" asp-action="Documents">Open Documents</a>
                    <a class="footer-mini-btn" asp-controller="Home" asp-action="ContactSupport">Contact &amp; Support</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
