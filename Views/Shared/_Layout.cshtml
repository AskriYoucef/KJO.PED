<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PED Intranet</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KJO.PED.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">PED Intranet</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Overview</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Organization" asp-action="Index">Organization</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="DivisionsRoles" asp-action="Index">Divisions &amp; Roles</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Applications" asp-action="Index">Applications</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Policies" asp-action="Index">Policies &amp; Procedures</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Documents" asp-action="Index">Documents</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="News" asp-action="Index">News &amp; Announcements</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="CompanyDirectory" asp-action="Index">Company Directory</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="EmployeeAccess" asp-action="Index">Employee Access</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="WeeklyHighlights" asp-action="Index">Weekly Highlights</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; @DateTime.Now.Year - PED Intranet
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
