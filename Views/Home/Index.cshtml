@{
    ViewData["Title"] = "Overview";
}

<section class="hero py-4">
    <div class="container d-flex flex-column flex-md-row align-items-start gap-4">
        <div class="hero-left">
            <h1 class="display-6">Overview</h1>
            <p class="lead text-muted">Bienvenue sur l'intranet du Petroleum Engineering & Exploration Department. Accédez rapidement aux outils et ressources ci‑dessous.</p>
            <div class="mt-3">
                <a class="btn btn-primary me-2" asp-controller="Home" asp-action="Index">Commencer</a>
                <a class="btn btn-outline-secondary" asp-controller="Documents" asp-action="Index">Documents</a>
            </div>
        </div>

        <aside class="hero-right ms-auto" style="min-width:220px;">
            <div class="card shadow-sm">
                <div class="card-body py-3">
                    <h6 class="mb-2">Ressources rapides</h6>
                    <ul class="list-unstyled mb-0">
                        <li><a href="/Policies" class="small">Policies &amp; Procedures</a></li>
                        <li><a href="/Documents" class="small">Documents</a></li>
                        <li><a href="/CompanyDirectory" class="small">Company Directory</a></li>
                    </ul>
                </div>
            </div>

            <div class="mt-3 text-muted small">
                <strong>Weekly Highlights</strong>
                <div class="mt-2">Soumettez, révisez et approuvez des points saillants hebdomadaires.</div>
                <div class="mt-2">
                    <a class="btn btn-sm btn-outline-primary me-2" asp-controller="WeeklyHighlights" asp-action="Submit">Soumettre</a>
                    <a class="btn btn-sm btn-secondary" asp-controller="WeeklyHighlights" asp-action="Review">Revue</a>
                </div>
            </div>
        </aside>
    </div>
</section>

<section class="container my-4">
    <div class="row">
        <div class="col-12">
            <h3 class="h5">À la une</h3>
            <p class="text-muted">Utilisez la navigation principale pour parcourir les sections de l'intranet. Les raccourcis à droite permettent d'accéder rapidement aux ressources les plus utilisées.</p>
        </div>
    </div>
</section>
