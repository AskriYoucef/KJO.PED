@{
    ViewData["Title"] = "Company Directory";
}

<section class="page-section">
    <div class="content-card mb-4">
        <div class="section-kicker">Directory</div>
        <h1 class="card-title-main">Company directory</h1>
        <p class="page-text mb-0">
            A central place to find department contacts, team points of contact and useful internal references.
        </p>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6 col-xl-4">
            <div class="info-card h-100">
                <h3 class="info-card-title">Department Management</h3>
                <p class="info-card-text">
                    Key contact information for management and department coordination.
                </p>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="info-card h-100">
                <h3 class="info-card-title">Technical Teams</h3>
                <p class="info-card-text">
                    Contact points for engineering, exploration, analysis and support activities.
                </p>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="info-card h-100">
                <h3 class="info-card-title">Shared Services</h3>
                <p class="info-card-text">
                    Internal support contacts for administration, IT coordination and related services.
                </p>
            </div>
        </div>
    </div>

    <div class="info-note">
        Recommended future step: connect this page to Active Directory or a database table
        so the directory becomes searchable and automatically maintainable.
    </div>
</section>