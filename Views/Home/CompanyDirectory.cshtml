@{
    ViewData["Title"] = "Department Directory";
}

<section class="page-section">
    <div class="page-shell">
        <div class="company-directory-page">
            <section class="directory-legacy-intro">
                <div class="directory-legacy-copy">
                    <span class="directory-kicker">Department</span>
                    <h1>Department Directory</h1>
                    <p>
                        Search PED contacts by name, position, division, extension or email.
                        The page keeps the same clean style as the rest of the portal, with a lighter filter area and clearer results.
                    </p>
                </div>
            </section>

            <section class="directory-search-panel directory-panel">
                <div class="directory-search-header">
                    <h2>Find a contact</h2>
                    <p>Use the search box and division filter below.</p>
                </div>

                <div class="directory-toolbar">
                    <div class="directory-filter">
                        <label for="directorySearch">Search</label>
                        <input id="directorySearch"
                               class="directory-control"
                               type="search"
                               placeholder="Search by name, position, email or extension" />
                    </div>

                    <div class="directory-filter">
                        <label for="directorySection">Division</label>
                        <select id="directorySection" class="directory-control">
                            <option value="">All divisions</option>
                            <option value="Data Management and Technology">Data Management and Technology</option>
                            <option value="Reservoir Management">Reservoir Management</option>
                            <option value="Geoseances">Geoseances</option>
                            <option value="Integrated Moduling and Studies">Integrated Moduling and Studies</option>
                            <option value="Planning and Business Support">Planning and Business Support</option>
                        </select>
                    </div>

                    <div class="directory-reset-wrap">
                        <button id="directoryReset" type="button" class="directory-reset">Clear filters</button>
                    </div>
                </div>
            </section>

            <section class="directory-results-panel directory-panel">
                <div class="directory-results-head">
                    <div>
                        <h2>Directory results</h2>
                        <p class="directory-results-subtitle">Updated presentation with smaller filters, division selector, and clearer row separators.</p>
                    </div>
                    <div class="directory-count-badge">
                        <span id="directoryResultCount" class="directory-count">8</span>
                        <span class="directory-count-label">contacts</span>
                    </div>
                </div>

