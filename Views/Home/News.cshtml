@{
    ViewData["Title"] = "News";
}

<section class="content-panel page-header-card">
    <div class="section-eyebrow">News</div>
    <h1>News &amp; Announcements</h1>
    <p>
        Department updates, PED notices and quick access to reference documents.
    </p>
</section>

<section class="feature-grid two-col news-grid">
    <article class="feature-card card-equal">
        <h2>Azure Information Protection Guide</h2>
        <p>
            Quick access to the Azure Information Protection user guide in PDF format.
        </p>
        <div class="action-row compact-actions">
            <a class="btn-pill-primary" href="@Url.Content("~/docs/azure-information-protection-guide.pdf")" target="_blank" rel="noopener">Open Azure Guide</a>
        </div>
    </article>

    <article class="feature-card card-equal">
        <h2>Operational Calendar 2026</h2>
        <p>
            Open the operational calendar directly from the portal for quick consultation.
        </p>
        <div class="action-row compact-actions">
            <a class="btn-pill-outline" href="@Url.Content("~/docs/operational-calendar-2026.pdf")" target="_blank" rel="noopener">Open Calendar PDF</a>
        </div>
    </article>
</section>
