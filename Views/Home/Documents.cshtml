@{
    ViewData["Title"] = "Documents";
}

<section class="page-section">
    <div class="content-card mb-4">
        <div class="section-kicker">Documents</div>
        <h1 class="card-title-main">Reference documents and department resources</h1>
        <p class="page-text mb-0">
            Access PED reference materials, procedures, templates and internal documentation from a single location.
        </p>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="content-card h-100">
                <div class="section-kicker">Featured Resource</div>
                <h2 class="quick-card-title">Operational Calendar 2026</h2>
                <p class="page-text">
                    Quick access to the KJO operational calendar for the current year.
                    This can later be downloaded and stored locally inside the portal if you prefer an internal copy.
                </p>

                <div class="action-row">
                    <a class="btn-pill-primary"
                       href="https://www.kjo.com.sa/irj/go/km/docs/documents/KJOWebSite/OPERATIONALCALANDER_EN_2026.pdf"
                       target="_blank" rel="noopener">
                        Open PDF
                    </a>

                    <a class="btn-pill-outline" asp-controller="Home" asp-action="EmployeeAccess">
                        Contact & Support
                    </a>
                </div>

                <div class="info-note">
                    Recommended next step later: place the PDF under <strong>wwwroot/docs</strong>
                    and open it from an internal local path instead of an external link.
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="content-card h-100">
                <div class="section-kicker">Document Library</div>
                <h2 class="quick-card-title">Suggested categories</h2>
                <ul class="document-list mb-0">
                    <li>Department procedures</li>
                    <li>Engineering standards and technical notes</li>
                    <li>Meeting templates and reporting formats</li>
                    <li>Official forms and administrative documents</li>
                    <li>Archived reference material</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6 col-xl-4">
            <div class="info-card h-100">
                <h3 class="info-card-title">Policies & Procedures</h3>
                <p class="info-card-text">
                    Official procedures, internal policies and operational guidance used by PED teams.
                </p>
                <div class="action-row">
                    <a class="btn-pill-outline" asp-controller="Home" asp-action="Documents">Open Section</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="info-card h-100">
                <h3 class="info-card-title">Templates & Forms</h3>
                <p class="info-card-text">
                    Standardized templates, reporting formats and administrative forms for daily activities.
                </p>
                <div class="action-row">
                    <a class="btn-pill-outline" asp-controller="Home" asp-action="Documents">Open Section</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="info-card h-100">
                <h3 class="info-card-title">Technical References</h3>
                <p class="info-card-text">
                    Supporting technical notes, engineering references and documentation useful for department work.
                </p>
                <div class="action-row">
                    <a class="btn-pill-outline" asp-controller="Home" asp-action="Documents">Open Section</a>
                </div>
            </div>
        </div>
    </div>
</section>