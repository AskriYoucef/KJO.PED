@{
    ViewData["Title"] = "Employee Access";
}

<section class="page-section">
    <div class="container">
        <div class="content-card mb-4">
            <div class="section-kicker">Employee Access</div>
            <h1 class="card-title-main">Employee services and useful access points</h1>
            <p class="page-text mb-0">
                Quick access to the most useful employee-related services, portals and internal resources.
            </p>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-xl-3">
                <div class="info-card h-100">
                    <h3 class="info-card-title mb-3">HR Services</h3>
                    <p class="info-card-text">
                        Access employee-related services, forms and general HR references.
                    </p>
                    <div class="action-row">
                        <a class="btn-pill-outline" href="#">Open</a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="info-card h-100">
                    <h3 class="info-card-title mb-3">Internal Systems</h3>
                    <p class="info-card-text">
                        Quick links to internal systems and commonly used employee platforms.
                    </p>
                    <div class="action-row">
                        <a class="btn-pill-outline" href="#">Open</a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="info-card h-100">
                    <h3 class="info-card-title mb-3">Forms & Requests</h3>
                    <p class="info-card-text">
                        Find request forms, access forms and useful employee documents.
                    </p>
                    <div class="action-row">
                        <a class="btn-pill-outline" href="#">Open</a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="info-card h-100">
                    <h3 class="info-card-title mb-3">Helpful Links</h3>
                    <p class="info-card-text">
                        A curated list of useful links frequently used by PED employees.
                    </p>
                    <div class="action-row">
                        <a class="btn-pill-outline" href="#">Open</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>