@model IEnumerable<KJO.PED.Models.WeeklyHighlight>
@{
    ViewData["Title"] = "Review Highlights";
}

<h1>Review Highlights</h1>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Submitted</th>
            <th>By</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach(var item in Model)
    {
        <tr>
            <td>@item.Title</td>
            <td>@item.SubmittedAt.ToLocalTime().ToString("g")</td>
            <td>@item.SubmittedBy</td>
            <td>
                <a class="btn btn-sm btn-outline-primary" asp-action="ApproveView" asp-route-id="@item.Id">Review</a>
            </td>
        </tr>
    }
    </tbody>
</table>
